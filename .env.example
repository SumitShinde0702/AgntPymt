# ── App (single root .env — loaded by server + client via Vite envDir) ──
NODE_ENV=development
PORT=3001

# Database (local file by default; use Turso libsql URL for cloud deploy)
DATABASE_URL=file:./dev.db
# TURSO_AUTH_TOKEN=   # required when DATABASE_URL is a remote libsql:// URL

# Client (Vite exposes VITE_* to browser)
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=AgntPymt MVP Demo

# Clerk (optional — app runs in demo mode without these)
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Hermes gateway (optional — Agent Console shows setup hint if offline)
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=

# LLM (negotiation dialogue in Agent Console)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Payments (live mode uses x402 + facilitator on Base Sepolia — not direct ERC20 transfer)
SIMULATE_PAYMENTS=true
DEMO_TRANSACTION_FEE_USD=0.01
EVM_PAY_TO_ADDRESS=
FACILITATOR_URL=https://x402.org/facilitator

# WalletConnect (optional — get free ID at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
