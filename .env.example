# ── App (single root .env — loaded by server + client via Vite envDir) ──
NODE_ENV=development
PORT=3001

# Database — PostgreSQL (local Docker or Cloud SQL)
# Local: docker compose -f deploy/docker/docker-compose.postgres.yml up -d
DATABASE_URL=postgresql://agntpymt:agntpymt@localhost:5432/agntpymt

# GCP — Hermes profile artifacts (SOUL, skills, config). Omit for local disk only.
# GCS_PROFILE_BUCKET=your-project-agntpymt-profiles
# GCS_PROFILE_PREFIX=hermes
# AGNTPYMT_PUBLIC_URL=https://your-service.run.app

# Client (Vite exposes VITE_* to browser)
VITE_API_URL=http://localhost:3001
VITE_APP_NAME=AgntPymt MVP Demo

# Clerk — set both keys (publishable can be shared via VITE_* name)
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Hermes gateway — must match API_SERVER_KEY in ~/.hermes/.env
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=change-me-local-dev

# MCP service key (must match AGNTPYMT_MCP_KEY in ~/.hermes/config.yaml mcp env)
AGNTPYMT_MCP_KEY=dev-mcp-key

# LLM (negotiation dialogue in Agent Console)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Payments — x402 EIP-3009 USDC on Base Sepolia (same protocol Coinbase ships; facilitator is pluggable)
# Testnet (no signup): https://x402.org/facilitator  |  Production: Coinbase CDP API + CDP_API_KEY_*
SIMULATE_PAYMENTS=true
DEMO_TRANSACTION_FEE_USD=0.01
EVM_PAY_TO_ADDRESS=
FACILITATOR_URL=https://x402.org/facilitator

# WalletConnect (optional — get free ID at https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=
