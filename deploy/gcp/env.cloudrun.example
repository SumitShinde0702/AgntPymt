# Copy to .env.gcp and fill before deploy. Do not commit secrets.

# ── Cloud Run (AgntPymt API + UI) ──────────────────────────────────────────
NODE_ENV=production
PORT=8080
AGNTPYMT_PUBLIC_URL=https://agntpymt-xxxxx.asia-southeast1.run.app

# Cloud SQL PostgreSQL (socket form for Cloud Run)
DATABASE_URL=postgresql://agntpymt:PASSWORD@/agntpymt?host=/cloudsql/PROJECT:asia-southeast1:agntpymt-db

# Hermes profiles → GCS
GCS_PROFILE_BUCKET=your-project-agntpymt-profiles
GCS_PROFILE_PREFIX=hermes
HERMES_HOME=/tmp/hermes

# Hermes gateway (GCE VM internal IP in same region)
HERMES_API_URL=http://10.128.0.2:8642
HERMES_API_KEY=generate-a-strong-key
AGNTPYMT_MCP_KEY=generate-a-strong-key

# Clerk
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Payments (Base Sepolia demo)
SIMULATE_PAYMENTS=false
DEMO_TRANSACTION_FEE_USD=0.01
EVM_PAY_TO_ADDRESS=0x...
FACILITATOR_URL=https://x402.org/facilitator

OPENAI_API_KEY=
VITE_API_URL=
